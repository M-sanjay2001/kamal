<div id="pac-container" style="position: relative;">
  <input id="searchInput" class="form-control mt-2 flexible-search-box" type="text" placeholder="City, State or ZIP Code" maxlength="256"/>
  <ul id="suggestions"></ul>
  <button id="clearInputButton" class="pt-2" type="button">&times;</button>
</div>

<script>
    const API_KEY = "AIzaSyDbzRSLIwGac8OGVK4_Meh3j2rzGkTV2rQ"; // Replace with your actual key
    const input = document.getElementById("searchInput");
    const suggestionsContainer = document.getElementById("suggestions");

    input.addEventListener("input", async function () {
        const query = input.value;
        if (query.length < 3) {
            suggestionsContainer.innerHTML = "";
            return;
        }

        try {
            const response = await fetch(`https://api.locationiq.com/v1/autocomplete.php?key=${API_KEY}&q=${encodeURIComponent(query)}&limit=10&format=json`);
            const results = await response.json();

            if (results.length === 0) {
                suggestionsContainer.innerHTML = "<li>No results found</li>";
                return;
            }

            suggestionsContainer.innerHTML = results
                .map(place => {
                    const address = place.display_name;
                    return `<li onclick="selectPlace('${address}')">${address}</li>`;
                })
                .join("");
        } catch (error) {
            suggestionsContainer.innerHTML = "<li>Error fetching results. Please try again.</li>";
            console.error("Error fetching location data:", error);
        }
    });

    function selectPlace(name) {
        input.value = name;
        suggestionsContainer.innerHTML = "";
    }
</script>

<style>
    #pac-container {
        position: relative;
        width: 300px;
    }
    #suggestions {
        list-style: none;
        padding: 0;
        margin: 0;
        background: #fff;
        border: 1px solid #ddd;
        position: absolute;
        width: 100%;
        max-height: 200px;
        overflow-y: auto;
        z-index: 1000;
    }
    #suggestions li {
        padding: 10px;
        cursor: pointer;
    }
    #suggestions li:hover {
        background: #f0f0f0;
    }
</style>
<!DOCTYPE html>
<html>
<head>
  <title>
    Simple Places Autocomplete
  </title>
  <script type="module" src="https://ajax.googleapis.com/ajax/libs/@googlemaps/extended-component-library/0.6.11/index.min.js">
  </script>
  <style>
